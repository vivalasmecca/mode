{
  "_note": "MODE intent layer. Defines which palette mode (light/neutral/dark) each component gets in each context. What those modes look like visually lives in tokens/theme.json \u2014 that is the brand's responsibility. Switch presets with: node agent/set-preset.js <preset-name>",
  "active_preset": "archetype-driven",
  "behavioral_tokens": {
    "_note": "Archetype-driven across all presets. Controls copy density, evidence level, CTA rules.",
    "Validator": {
      "require_trust_signal": true,
      "allow_secondary_cta": true,
      "subhead_policy": "always",
      "copy_density": "medium",
      "evidence_density": "high"
    },
    "Mover": {
      "require_trust_signal": false,
      "allow_secondary_cta": false,
      "subhead_policy": "optional",
      "copy_density": "low",
      "evidence_density": "low"
    },
    "Explorer": {
      "require_trust_signal": false,
      "allow_secondary_cta": true,
      "subhead_policy": "always",
      "copy_density": "high",
      "evidence_density": "medium"
    }
  },
  "presets": {
    "funnel-driven": {
      "description": "Dark = decision signal. Emphasis accumulates toward conversion \u2014 trust anchors and commitment moments are dark, top-of-funnel is light.",
      "palette_driver": "funnel_stage",
      "palette_key": "funnel_stage",
      "palette_map": {
        "NavigationHeader": {
          "awareness": "light",
          "consideration": "light",
          "decision": "light",
          "conversion": "light"
        },
        "HeroPrimary": {
          "awareness": "light",
          "consideration": "light",
          "decision": "dark",
          "conversion": "dark"
        },
        "SocialProofBar": {
          "awareness": "neutral",
          "consideration": "dark",
          "decision": "dark",
          "conversion": "dark"
        },
        "StatBlock": {
          "awareness": "neutral",
          "consideration": "dark",
          "decision": "dark",
          "conversion": "dark"
        },
        "FeatureGrid": {
          "awareness": "light",
          "consideration": "neutral",
          "decision": "neutral",
          "conversion": "neutral"
        },
        "TestimonialSingle": {
          "awareness": "neutral",
          "consideration": "dark",
          "decision": "dark",
          "conversion": "dark"
        },
        "PricingCard": {
          "awareness": "light",
          "consideration": "neutral",
          "decision": "dark",
          "conversion": "dark"
        },
        "CTABanner": {
          "awareness": "dark",
          "consideration": "dark",
          "decision": "dark",
          "conversion": "dark"
        },
        "FooterMinimal": {
          "awareness": "light",
          "consideration": "light",
          "decision": "light",
          "conversion": "light"
        }
      }
    },
    "feature-emphasis": {
      "description": "Component role drives palette \u2014 not funnel stage. Trust and conversion components always dark; hero and nav always light; informational sections neutral. Visual emphasis is structural, not momentary.",
      "palette_driver": "component_role",
      "palette_map": {
        "NavigationHeader": "light",
        "HeroPrimary": "light",
        "HeroStatement": "light",
        "FeatureGrid": "dark",
        "StatBlock": "dark",
        "SocialProofBar": "dark",
        "TestimonialSingle": "dark",
        "PricingCard": "dark",
        "CTABanner": "dark",
        "ContentSection": "neutral",
        "FooterMinimal": "neutral"
      }
    },
    "archetype-driven": {
      "description": "Dark = identity signal. Visual language expresses who the user is. Validator gets authority and weight (heavy dark). Mover gets minimal light with one dark CTA punch. Explorer gets all-neutral \u2014 open, spacious, no urgency.",
      "palette_driver": "archetype",
      "palette_key": "archetype",
      "palette_map": {
        "NavigationHeader": {
          "Validator": "light",
          "Mover": "light",
          "Explorer": "light"
        },
        "HeroPrimary": {
          "Validator": "dark",
          "Mover": "light",
          "Explorer": "neutral"
        },
        "SocialProofBar": {
          "Validator": "dark",
          "Mover": "neutral",
          "Explorer": "neutral"
        },
        "StatBlock": {
          "Validator": "dark",
          "Mover": "neutral",
          "Explorer": "neutral"
        },
        "FeatureGrid": {
          "Validator": "dark",
          "Mover": "light",
          "Explorer": "neutral"
        },
        "TestimonialSingle": {
          "Validator": "dark",
          "Mover": "light",
          "Explorer": "neutral"
        },
        "PricingCard": {
          "Validator": "neutral",
          "Mover": "neutral",
          "Explorer": "light"
        },
        "CTABanner": {
          "Validator": "dark",
          "Mover": "dark",
          "Explorer": "neutral"
        },
        "FooterMinimal": {
          "Validator": "light",
          "Mover": "light",
          "Explorer": "light"
        }
      }
    }
  }
